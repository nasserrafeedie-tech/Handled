// §5 Data model — Postgres is the source of truth.
// Enums mirror packages/contracts/src/enums.ts (the shared vocabulary).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────
enum TrustLevel {
  approve_all
  auto_low_risk
  full_auto
}

enum CustomerStatus {
  onboarding
  active
  paused
  cancelled
}

// Kept deliberately short — see the Platform enum in packages/contracts for why
// X, LinkedIn and YouTube were dropped. TikTok stays for its image carousels.
enum Platform {
  instagram
  facebook
  tiktok
  threads
}

enum PostArchetype {
  promo
  behind_the_scenes
  testimonial
  educational_tip
  product_spotlight
  seasonal
  ugc_repost
  were_open
}

enum PostStatus {
  draft
  pending_approval
  approved
  scheduled
  published
  failed
  cancelled
}

enum ApprovalState {
  not_required
  awaiting_owner
  approved
  rejected
}

enum ModerationState {
  pending
  passed
  blocked
}

enum RiskLevel {
  low
  high
}

enum MediaKind {
  image
  video
}

enum MediaSource {
  owner_upload
  ai_generated
  assembled
}

enum ShotListStatus {
  requested
  fulfilled
  skipped
  expired
}

enum MessageDirection {
  inbound
  outbound
}

enum TaskStatus {
  emitted
  running
  done
  needs_owner_input
  pending_approval
  failed
}

// ─── customers ───────────────────────────────────────────────────────────
model Customer {
  id              String         @id @default(uuid()) @db.Uuid
  phone           String         @unique
  businessName    String?
  // IANA zone the business actually operates in. Every scheduled time is a
  // wall-clock hour in here — without it, a 9am post lands at 2am. Defaulted
  // rather than asked during onboarding to keep the interview to five
  // questions; the owner can correct it in conversation.
  timezone        String         @default("America/Los_Angeles")
  planTier        String         @default("starter")
  // Generated photography is opt-in and off by default. Not because of the
  // plan tier — that gates access — but because posting model-made imagery is
  // a decision about how the business represents itself, and it is the owner's
  // to make. See OWNER_CONSENT_COPY in graphics/image-prompt.ts.
  aiImagesOptIn   Boolean        @default(false)
  aiImagesOptInAt DateTime?
  // When the last monthly results recap went out. Guards against sending twice
  // in a billing cycle — the sweep runs daily and the send window is several
  // days wide, so without this an owner would get the same recap every day.
  lastRecapAt     DateTime?
  trustLevel      TrustLevel     @default(approve_all) // §8: everyone starts here
  status          CustomerStatus @default(onboarding)
  stripeCustomerId String?       @unique
  // Referral loop: my shareable code, and the code that brought me here.
  referralCode    String?        @unique
  referredByCode  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  brandProfile     BrandProfile?
  connectedAccounts ConnectedAccount[]
  posts            Post[]
  mediaAssets      MediaAsset[]
  shotListRequests ShotListRequest[]
  // Which playbook archetype plans this business's weeks, and how sure the
  // classifier was. Null = not yet classified (or research still running).
  archetypeSlug       String?
  archetypeConfidence Float?

  conversation     Conversation?
  tasks            Task[]
  metrics          Metric[]
  queuedTexts      QueuedText[]
  preferences      CustomerPreference[]

  @@map("customers")
}

// The Playbook Engine's source of truth: one row per business archetype
// ("cafes-coffee-shops"), holding the strategy Handled plans with. Seeded from
// social-playbook.md, extended automatically when a novel business type signs
// up, and refreshed when it goes stale. The Markdown doc is a rendered mirror
// of this table, never the other way round.
model PlaybookArchetype {
  id            String   @id @default(uuid()) @db.Uuid
  slug          String   @unique
  title         String
  // Synonyms the classifier matches against ("espresso bar", "juice bar").
  mapsFrom      String[]
  // Structured strategy. Json rather than columns because the shape is the
  // playbook's, and it evolves with the research — see PlaybookFields.
  platforms     Json
  pillars       Json
  topFormats    Json
  cadence       Json
  reels         Json
  photoStyle    String
  captionHooks  Json
  discovery     Json
  offers        Json
  seasonal      Json
  mistakes      Json
  revenueMetric String
  // URLs backing the research pass — every claim stays auditable.
  sources       Json     @default("[]")
  confidence    Float    @default(1)
  // seed | researched | needs_review
  status        String   @default("seed")
  researchedAt  DateTime @default(now())
  // How many customers plan from this archetype — drives refresh priority.
  usageCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@map("playbook_archetypes")
}

// ─── llm_usage (what each customer actually costs to serve) ──────────────
// Margin is ~90% on the assumption that model calls are cheap. That assumption
// has never been measured: a chatty owner who revises every draft costs many
// times what a quiet one does, and nothing recorded the difference.
//
// Token counts are stored rather than dollars. Counts are facts that do not
// change; a price does, and a rate correction should never require rewriting
// history. Cost is derived at read time — see llm/pricing.ts.
// ─── customer_preferences (the per-customer context engine) ──────────────
// What we have learned about how ONE business likes its posts, on top of the
// brand profile it gave us at signup. The profile is what the owner said once;
// this is what they keep telling us since — "I don't like that color", "keep
// them short" — pulled from their own words and remembered.
//
// Deliberately conservative. Only standing preferences are stored, never
// one-off edits to a single post, and each carries how many times we have seen
// it: said once is tentative, said again is confirmed. So a throwaway comment
// can't quietly rewrite how every future post is written.
model CustomerPreference {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @db.Uuid
  // The preference as it reads in the prompt: a short instruction.
  text       String
  // like | dislike | rule — for grouping and the owner-facing view.
  kind       String   @default("rule")
  // How many separate times the owner has expressed this. 1 = tentative.
  timesSeen  Int      @default(1)
  // Where it came from, for the audit trail and "what you've told us".
  source     String   @default("conversation")
  // Off, rather than deleted, when superseded or the owner disowns it —
  // history stays, but an inactive preference never reaches the prompt.
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, active])
  @@map("customer_preferences")
}

model LlmUsage {
  id           String   @id @default(uuid()) @db.Uuid
  // Null for work not tied to one customer (playbook research, for instance,
  // which is paid once and reused by everyone in that trade).
  customerId   String?  @db.Uuid
  model        String
  tier         String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  // Cached input is billed differently from fresh input — reads are a fraction
  // of the price, writes a premium. Kept apart so the saving from prompt
  // caching is visible rather than blended away.
  cacheReadTokens  Int  @default(0)
  cacheWriteTokens Int  @default(0)
  createdAt    DateTime @default(now())

  @@index([customerId, createdAt])
  @@index([createdAt])
  @@map("llm_usage")
}

// ─── archetype_performance (Flow 4: what actually worked) ────────────────
// The research pass says what should work for a kind of business. This says
// what did — measured from real posts, pooled across every customer on the
// same archetype, so the tenth coffee shop plans from nine shops' results
// instead of from the same starting guess.
//
// Sums rather than averages: an average cannot be updated incrementally
// without keeping the sample anyway, and rates computed from stored totals
// stay correct when a late metric arrives.
//
// Pooled only in aggregate. No caption, no customer, and nothing identifying
// crosses between businesses — just the counts.
model ArchetypePerformance {
  id            String   @id @default(uuid()) @db.Uuid
  // Which playbook archetype (the kind of business).
  archetypeSlug String
  // Which post format within it (promo, behind_the_scenes, …).
  postArchetype String
  platform      String
  // How many posts back this row. Below MIN_SAMPLES it is not acted on.
  samples       Int      @default(0)
  impressions   BigInt   @default(0)
  engagements   BigInt   @default(0)
  updatedAt     DateTime @updatedAt

  @@unique([archetypeSlug, postArchetype, platform])
  @@index([archetypeSlug])
  @@map("archetype_performance")
}

// Unprompted texts held for the recipient's 8:00–21:00 local window (TCPA
// quiet hours). Replies to an active conversation bypass this entirely.
model QueuedText {
  id         String    @id @default(uuid()) @db.Uuid
  customerId String    @db.Uuid
  body       String
  sendAfter  DateTime
  sentAt     DateTime?
  createdAt  DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([sentAt, sendAfter])
  @@map("queued_texts")
}

// ─── connected_accounts (tokens encrypted at rest, §8) ───────────────────
model ConnectedAccount {
  id             String   @id @default(uuid()) @db.Uuid
  customerId     String   @db.Uuid
  platform       Platform
  // Ciphertext only — never store plaintext tokens. Encryption in TokenCrypto.
  accessTokenEnc String
  refreshTokenEnc String?
  scopes         String[]
  postForMeRef   String?  // Post for Me account reference
  externalHandle String?
  revoked        Boolean  @default(false)
  // Meta's Business tokens last ~59 days and cannot be refreshed without the
  // owner, so an expiry is a date we have to plan around rather than an error
  // we handle. Null means "no known expiry" (some platforms don't lapse).
  expiresAt      DateTime?
  // When we last texted about reconnecting. Stops a daily sweep from nagging.
  reauthAskedAt  DateTime?
  connectedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, platform])
  @@index([customerId])
  @@index([expiresAt])
  @@map("connected_accounts")
}

// ─── brand_profiles (persistent per-customer memory; cached into LLM calls) ─
model BrandProfile {
  id                 String   @id @default(uuid()) @db.Uuid
  customerId         String   @unique @db.Uuid
  businessType       String?
  voiceTone          String?
  targetCustomer     String?
  offers             String[]
  dosAndDonts        String[]
  blackoutTopics     String[]
  // Null until the owner answers during onboarding — a DB default would make
  // the interview think the question was already answered and skip it.
  postingFrequency   Int?
  brandColors        String[]
  // Type personality for the graphics engine (modern | editorial | bold | luxe),
  // derived from the business at the end of onboarding. Persisted so a brand
  // looks the same every week.
  visualStyle        String?
  // Bespoke content strategy written by Claude at onboarding completion from
  // THIS business's own words (mix, ideas, photo asks, reel recipe, hook).
  // Null = fall back to the static vertical playbook. One call per customer.
  contentStrategy    Json?
  logoRef            String?
  referencePhotoRefs String[]
  // Onboarding progress is tracked as which fields are filled, not a step
  // counter (§6) — persisted so hours-long gaps resume cleanly.
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("brand_profiles")
}

// ─── posts ───────────────────────────────────────────────────────────────
model Post {
  id              String          @id @default(uuid()) @db.Uuid
  customerId      String          @db.Uuid
  archetype       PostArchetype
  platform        Platform
  caption         String?
  // Screen-reader description AND a real ranking input on IG/FB — the
  // platforms read it to understand the image. Written at draft time.
  altText         String?
  hashtags        String[]
  mediaRefs       String[]
  scheduledTime   DateTime?
  status          PostStatus      @default(draft)
  approvalState   ApprovalState   @default(not_required)
  moderationState ModerationState @default(pending)
  riskLevel       RiskLevel       @default(low)
  externalPostId  String?
  failureReason   String?
  // How an approval was obtained when it did not arrive by text — "Dr.
  // Rafeedie, in person 22 Jul". Null for the normal SMS path, where the
  // owner's actual reply is already stored on the conversation. Exists so that
  // posting on someone's behalf always leaves a trail naming the human who said
  // yes; an approval nobody can trace is the one thing we must not have.
  approvalNote    String?
  // Which playbook archetype this post was planned from. Named `playbookSlug`
  // and not `archetypeSlug` because `archetype` above is the POST's format
  // (promo, behind_the_scenes) — a different axis entirely. Stamped at draft
  // time so per-archetype performance can be aggregated later (engine Flow 4).
  playbookSlug    String?
  // Whether any attached image was made by a model rather than a camera.
  // Stored explicitly instead of derived from the media rows because it has to
  // travel to the platform: Instagram and TikTok both require AI-generated
  // content to be declared, and TikTok takes it as a field on the publish call.
  // A disclosure that depends on a join is a disclosure that will eventually
  // be missed.
  aiGeneratedMedia Boolean        @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  customer Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  media    MediaAsset[]
  metrics  Metric[]
  shotList ShotListRequest[]

  @@index([customerId, status])
  @@index([status, scheduledTime])
  @@map("posts")
}

// ─── media_assets (R2) ───────────────────────────────────────────────────
model MediaAsset {
  id          String      @id @default(uuid()) @db.Uuid
  customerId  String      @db.Uuid
  postId      String?     @db.Uuid
  kind        MediaKind
  source      MediaSource
  r2Key       String      @unique
  contentType String
  width       Int?
  height      Int?
  createdAt   DateTime    @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  post     Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@map("media_assets")
}

// ─── shot_list_requests (outstanding asks to the owner) ──────────────────
model ShotListRequest {
  id          String         @id @default(uuid()) @db.Uuid
  customerId  String         @db.Uuid
  postId      String?        @db.Uuid
  prompt      String
  status      ShotListStatus @default(requested)
  fulfilledBy String?        @db.Uuid // media_assets.id
  askedAt     DateTime       @default(now())
  fulfilledAt DateTime?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  post     Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([customerId, status])
  @@map("shot_list_requests")
}

// ─── metrics ─────────────────────────────────────────────────────────────
model Metric {
  id             String   @id @default(uuid()) @db.Uuid
  postId         String   @db.Uuid
  customerId     String   @db.Uuid
  externalPostId String?
  impressions    Int      @default(0)
  likes          Int      @default(0)
  comments       Int      @default(0)
  shares         Int      @default(0)
  saves          Int      @default(0)
  fetchedAt      DateTime @default(now())

  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([customerId, fetchedAt])
  @@map("metrics")
}

// ─── conversations / messages (Concierge SMS history + interview state) ──
model Conversation {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @unique @db.Uuid
  // Handled interprets what owners say instead of making them memorize
  // keywords, so a consequential or unclear reading gets confirmed first.
  // These hold the pending question: what we think they asked for, and when.
  // Stale ones are ignored — a "yes" an hour later isn't answering this.
  pendingIntent   String?
  pendingIntentAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("conversations")
}

model Message {
  id             String           @id @default(uuid()) @db.Uuid
  conversationId String           @db.Uuid
  direction      MessageDirection
  body           String?
  mediaUrls      String[]
  twilioSid      String?          @unique
  // When a human carried this text to the customer by hand, during the window
  // where Handled composes messages but cannot send them. Null means either
  // "sent normally over SMS" or "still waiting to be relayed" — the outbox
  // tells them apart by only ever looking at manual-relay conversations.
  relayedAt      DateTime?
  createdAt      DateTime         @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ─── tasks / results (§4 audit log — every Task and Result is logged) ────
model Task {
  id               String     @id @default(uuid()) @db.Uuid
  customerId       String     @db.Uuid
  type             String
  payload          Json
  requiresApproval Boolean    @default(false)
  createdBy        String // 'concierge' | 'cron'
  status           TaskStatus @default(emitted)
  createdAt        DateTime   @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  result   Result?

  @@index([customerId, createdAt])
  @@index([status])
  @@map("tasks")
}

model Result {
  id              String   @id @default(uuid()) @db.Uuid
  taskId          String   @unique @db.Uuid
  status          String
  summaryForOwner String
  data            Json?
  error           Json?
  createdAt       DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("results")
}

// ─── leads (pre-launch waitlist + interested visitors) ───────────────────
// Stripe delivers each webhook AT LEAST once, not exactly once — a redelivery
// after a timeout is normal operation, not an error. Without a record of what
// has already been handled, a repeated checkout.session.completed runs
// onboarding twice and the new customer's first experience of Handled is being
// texted the same welcome message twice.
//
// The event id is the primary key, so the insert itself is the lock: a
// duplicate fails the unique constraint and we skip. No read-then-write race.
model StripeWebhookEvent {
  id         String   @id
  type       String
  receivedAt DateTime @default(now())

  @@map("stripe_webhook_events")
}

model Lead {
  id             String    @id @default(uuid()) @db.Uuid
  phone          String    @unique
  email          String?
  source         String    @default("website")
  notified       Boolean   @default(false)
  // TCPA audit trail: the exact consent language shown and when it was agreed to.
  smsConsent     Boolean?
  smsConsentText String?
  smsConsentAt   DateTime?
  createdAt      DateTime  @default(now())

  @@map("leads")
}
