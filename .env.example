# ─── Core ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
PUBLIC_BASE_URL=http://localhost:3001

# ─── Database (Postgres — Supabase or Neon) ──────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/smm?schema=public

# ─── Redis / BullMQ ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Twilio SMS (the product's channel) ──────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=

# ─── LLM (Anthropic — Haiku 4.5 bulk, Sonnet 5 voice/planning) ───────────
ANTHROPIC_API_KEY=
LLM_MODEL_BULK=claude-haiku-4-5
LLM_MODEL_VOICE=claude-sonnet-5

# ─── Image generation ────────────────────────────────────────────────────
# OpenAI GPT Image is the default (chosen after a 4-model head-to-head).
# Set OPENAI_API_KEY to turn generated photos on. FAL/FLUX stays wired as a
# fallback — set FAL_API_KEY instead and it's used automatically if no OpenAI
# key is present. OPENAI_IMAGE_MODEL overrides the model id if it changes.
OPENAI_API_KEY=
# OPENAI_IMAGE_MODEL=gpt-image-2
FAL_API_KEY=
REPLICATE_API_TOKEN=

# ─── Publishing (Post for Me — unified posting API) ──────────────────────
POST_FOR_ME_API_KEY=
POST_FOR_ME_BASE_URL=https://api.postforme.dev

# ─── Storage (Cloudflare R2) ─────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=smm-media
R2_PUBLIC_BASE_URL=

# ─── Token encryption at rest (§8) — 32-byte key, base64 ─────────────────
TOKEN_ENCRYPTION_KEY=

# ─── Payments (Stripe) ───────────────────────────────────────────────────
# Set the secret key + the three Price IDs to make the /billing buttons live.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=
# Where Stripe sends the customer back after checkout (your marketing site).
PUBLIC_SITE_URL=https://aissm-web.vercel.app

# ─── Web app (apps/web) ──────────────────────────────────────────────────
# Point the marketing site at your deployed backend to make checkout live.
NEXT_PUBLIC_API_URL=

# ─── Observability ───────────────────────────────────────────────────────
SENTRY_DSN=
POSTHOG_KEY=
