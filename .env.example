# ─── Core ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
PUBLIC_BASE_URL=http://localhost:3001

# ─── Database (Postgres — Supabase or Neon) ──────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/smm?schema=public

# ─── Redis / BullMQ ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Twilio SMS (the product's channel) ──────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=

# ─── LLM (Anthropic — Haiku 4.5 bulk, Sonnet 5 voice/planning) ───────────
ANTHROPIC_API_KEY=
LLM_MODEL_BULK=claude-haiku-4-5
LLM_MODEL_VOICE=claude-sonnet-5

# ─── Image generation (via FAL / Replicate) ──────────────────────────────
FAL_API_KEY=
REPLICATE_API_TOKEN=

# ─── Publishing (Post for Me — unified posting API) ──────────────────────
POST_FOR_ME_API_KEY=
POST_FOR_ME_BASE_URL=https://api.postforme.dev

# ─── Storage (Cloudflare R2) ─────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=smm-media
R2_PUBLIC_BASE_URL=

# ─── Token encryption at rest (§8) — 32-byte key, base64 ─────────────────
TOKEN_ENCRYPTION_KEY=

# ─── Payments (Stripe) ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Observability ───────────────────────────────────────────────────────
SENTRY_DSN=
POSTHOG_KEY=
